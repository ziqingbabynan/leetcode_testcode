#这个符合要求的数一定可以写成3*3*3*3*5*5*5*5*2*2*2*2.......的格式，依次剥离这个数中的3，5，2，最后如果n值为1即为符合要求，为其他数即不符合。整体借鉴了灵茶大佬的思想，最后的检验操作有所不同。
class Solution:
    def isUgly(self, n: int) -> bool:
            if n <= 0:
                return False
            while n % 3 == 0:
                n //= 3
            while n % 5 == 0:
                n //= 5
            while n % 2 == 0:
                n //= 2
            return n==1
